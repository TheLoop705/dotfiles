# herdr runtime artifacts (regenerated at runtime; never commit)
home/.config/herdr/*.log
home/.config/herdr/session.json
home/.config/herdr/*.sock

# macOS + nix build noise
.DS_Store
result
result-*

# dictation-daemon build output (rebuilt by home.activation, never commit)
pkgs/dictation-daemon/target/

# no-mistakes local validation state - never commit in this public repo
.no-mistakes/

# Claude machine-local overrides and provider configuration
home/.claude/settings.local.json
home/.claude/*.env
